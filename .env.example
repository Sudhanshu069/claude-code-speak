# Google Cloud TTS
# Create a service account key at https://console.cloud.google.com
# Enable Text-to-Speech API for your project
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ElevenLabs (alternative provider)
# Get your API key from https://elevenlabs.io/settings
ELEVENLABS_API_KEY=your-api-key-here
